# Hikvision LAN agent (RabbitMQ only — no HTTP server)
# cp .env.example .env

DEBUG=false

# Zorunlu: Go API ile aynı broker. Kuyruk: hikvision.gateway.requests.<HIKVISION_GATEWAY_ORG_ID sanitize>
# TLS için: amqps://kullanici:sifre@host:5671/  (RabbitMQ’da SSL dinleyicisi genelde 5671)
HIKVISION_GATEWAY_AMQP_URL=amqps://admin:accessonkey**99@ec2-16-16-155-120.eu-north-1.compute.amazonaws.com:5671

# Zorunlu: Bu agent'ın hizmet verdiği kuruluş (Go API / JWT organization id string — genelde UUID)
HIKVISION_GATEWAY_ORG_ID=4fe71533-dd98-4bf8-bd8f-d139fd14c824
# amqps kullanıyorsan: doğrulama ve CA (üretimde CA dosyası önerilir)
HIKVISION_GATEWAY_AMQP_SSL_VERIFY=true
# Docker compose: ca_certificate.pem → /etc/ssl/rabbitmq/ca.pem mount; bu yolu kullanın:
HIKVISION_GATEWAY_AMQP_SSL_CAFILE=./ca_certificate.pem
HIKVISION_GATEWAY_AMQP_SSL_VERIFY=true
# Farklı host PEM yolu (compose volume sol tarafı): RABBITMQ_CA_HOST_FILE=/home/ubuntu/rabbit_ssl/ca.pem
# Kendi imzalı broker / lab (önerilmez): HIKVISION_GATEWAY_AMQP_SSL_VERIFY=false
# Kalıcı çözüm: CA’yı keyUsage ile yeniden üretin (bkz. docs/RABBIT_HIKVISION_GATEWAY_KILAVUZU.md §9.5).

# İsteğe bağlı: Go ISAPI mesajında username/password yoksa veya şifre boşsa kullanılır
HIKVISION_DEVICE_USERNAME=admin
HIKVISION_DEVICE_PASSWORD=idenfit1
HIKVISION_ISAPI_INSECURE_SKIP_VERIFY=true

# Başlangıçta ve referans için: ilk SADP tarama süresi (saniye)
HIK_SADP_STARTUP_TIMEOUT=3.0
